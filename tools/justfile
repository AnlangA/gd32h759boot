set shell := ["powershell.exe", "-NoLogo", "-NoProfile", "-Command"]

# Format command to format C files in Driver, Lib, and User directories
format:
    @echo "Formatting C files in Driver, Lib, and User directories..."
    @Get-ChildItem -Path ../Driver,../Lib,../User -Recurse -Include *.c,*.h | ForEach-Object { clang-format -i --style=file:../tools/code.clang-format $_.FullName }
    @echo "Formatting complete!"

# Build the Keil project and copy build log to project root
build:
    & "C:/Program Files/Keil/UV4/UV4.exe" -b ../Project/gd32h759temple.uvprojx -j0
    Copy-Item ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Rebuild (clean + build) the Keil project
rebuild:
    & "C:/Program Files/Keil/UV4/UV4.exe" -r ../Project/gd32h759temple.uvprojx -j0
    Copy-Item ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Show errors from the build log
errors:
    @if (Test-Path ../build_log.htm) { Select-String -Path ../build_log.htm -Pattern "error" -AllMatches } else { echo "No errors found or build_log.htm does not exist." }

# Show warnings from the build log
warnings:
    @if (Test-Path ../build_log.htm) { Select-String -Path ../build_log.htm -Pattern "warning" -AllMatches } else { echo "No warnings found or build_log.htm does not exist." }

# Clean build output files
clean:
    Remove-Item -Path ../Project/Output/*.o,../Project/Output/*.d,../Project/Output/*.axf,../Project/Output/*.htm,../Project/Output/*.hex,../Project/Output/*.lnp,../build_log.htm -Force -ErrorAction SilentlyContinue
    @echo "Clean done."
