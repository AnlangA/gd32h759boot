set shell := ["bash", "-c"]

# Format C files in App directory with clang-format
format:
    @command -v clang-format >/dev/null 2>&1 || { echo "Error: clang-format not found. Install LLVM/Clang and add to PATH." >&2; exit 1; }
    @echo "Formatting C files in App..."
    @find ../App -name '*.c' -o -name '*.h' | xargs clang-format -i --style=file:../tools/code.clang-format
    @echo "Formatting complete!"

# Build the Keil project and copy build log to project root
build:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    UV4 -b ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @cp ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Rebuild (clean + build) the Keil project
rebuild:
    @rm -f ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    UV4 -r ../Project/gd32h759temple.uvprojx -j0
    @for i in {1..60}; do if [ -f ../Project/Output/gh32h759temple.build_log.htm ] && grep -q 'Error(s)' ../Project/Output/gh32h759temple.build_log.htm; then break; fi; sleep 0.5; done
    @cp ../Project/Output/gh32h759temple.build_log.htm ../build_log.htm
    @echo "Build log copied to ../build_log.htm"

# Show errors from the build log
errors:
    @if [ -f ../build_log.htm ]; then grep -i 'error' ../build_log.htm; else echo "No errors found or build_log.htm does not exist."; fi

# Show warnings from the build log
warnings:
    @if [ -f ../build_log.htm ]; then grep -i 'warning' ../build_log.htm; else echo "No warnings found or build_log.htm does not exist."; fi

# Generate ECDSA-P256 key pair and inject public key into bootutil_keys.c
keygen pem="../keys/ecdsa256.pem":
    python ./genkey.py {{pem}} ../Port/src/bootutil_keys.c

# Clean build output files
clean:
    @rm -f ../Project/Output/*.o ../Project/Output/*.d ../Project/Output/*.axf ../Project/Output/*.htm ../Project/Output/*.hex ../Project/Output/*.lnp ../build_log.htm
    @echo "Clean done."
